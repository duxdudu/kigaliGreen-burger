rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    // User Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() > 0 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // Order Validation
    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.items is list &&
             data.items.size() > 0 &&
             data.total is number &&
             data.total >= 0 &&
             data.createdAt is timestamp &&
             (!('status' in data) || (data.status is string && data.status.size() <= 50)) &&
             (!('deliveryTime' in data) || (data.deliveryTime is string && data.deliveryTime.size() <= 50));
    }

    // Favorite Validation
    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'itemId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.itemId is string &&
             data.itemId.size() <= 100 &&
             data.createdAt is timestamp;
    }

    // Routes
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email;

      // Orders Subcollection
      match /orders/{orderId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(orderId);
        allow create: if isOwner(userId) && isValidId(orderId) && isValidOrder(incoming());
        allow update, delete: if false; // Orders are immutable history
      }

      // Favorites Subcollection
      match /favorites/{favoriteId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(favoriteId);
        allow create: if isOwner(userId) && isValidId(favoriteId) && isValidFavorite(incoming());
        allow delete: if isOwner(userId) && isValidId(favoriteId);
      }
    }
  }
}
